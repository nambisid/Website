# Database
MONGODB_URI=mongodb://localhost:27017/stitch-and-bloom

# JWT
JWT_SECRET=your-64-char-random-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Razorpay (from dashboard.razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (SendGrid)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=orders@stitchandbloom.com
EMAIL_FROM_NAME=Stitch & Bloom

# App
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
